
  <h1>{{title}}</h1>

  <h2>{{recipeName}}</h2>

  <h3>Ingredients</h3>
  <ul>
    {{#each ingredients}}
      <li>{{this}}</li>
    {{/each}}
  </ul>

  <h3>Instructions</h3>
  <ol>
    {{#each instructions}}
      <li>{{this}}</li>
    {{/each}}
  </ol>

  <p><a href="/">Create another recipe</a></p>
